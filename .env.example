# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────────────────────────
# Local dev/tests use mongodb-memory-server and do NOT need this.
# Required in production (MongoDB Atlas connection string).
MONGODB_URI=mongodb://127.0.0.1:27017/chatapp

# ─── Auth (JWT) ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TTL=15m
REFRESH_TTL=30d

# ─── Media / storage ────────────────────────────────────────────────────────
# When unset, the local filesystem fake storage adapter is used (dev/tests).
# In production set the Vercel Blob token to use real blob storage.
BLOB_READ_WRITE_TOKEN=
MAX_UPLOAD_BYTES=5242880

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_PORTAL_ORIGIN=http://localhost:3001

# ─── Rate limiting (optional, production) ───────────────────────────────────
UPSTASH_REDIS_URL=
